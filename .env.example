# ============================================
# Hospital Integration System - Environment Variables
# Copy this to .env and adjust values as needed
# ============================================

# --- RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=hospital_admin
RABBITMQ_PASS=hospital_secret_2024
RABBITMQ_MANAGEMENT_PORT=15672

# --- Registrasi Service (PostgreSQL) ---
REGISTRASI_DB_HOST=postgres-registrasi
REGISTRASI_DB_PORT=5432
REGISTRASI_DB_USER=registrasi_user
REGISTRASI_DB_PASS=registrasi_pass_2024
REGISTRASI_DB_NAME=registrasi_db

# --- EMR Service (MongoDB) ---
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USER=emr_user
MONGODB_PASS=emr_pass_2024
MONGODB_DB=emr_db

# --- Farmasi Service (MySQL) ---
FARMASI_DB_HOST=mysql-farmasi
FARMASI_DB_PORT=3306
FARMASI_DB_USER=farmasi_user
FARMASI_DB_PASS=farmasi_pass_2024
FARMASI_DB_NAME=farmasi_db
MYSQL_ROOT_PASSWORD=root_pass_2024

# --- Billing Service (PostgreSQL) ---
BILLING_DB_HOST=postgres-billing
BILLING_DB_PORT=5432
BILLING_DB_USER=billing_user
BILLING_DB_PASS=billing_pass_2024
BILLING_DB_NAME=billing_db

# --- Service URLs (internal Docker network) ---
REGISTRASI_SERVICE_HOST=registrasi-service
REGISTRASI_SERVICE_PORT=8001
EMR_SERVICE_HOST=emr-service
EMR_SERVICE_PORT=8002
FARMASI_SERVICE_HOST=farmasi-service
FARMASI_SERVICE_PORT=8003
BILLING_SERVICE_HOST=billing-service
BILLING_SERVICE_PORT=8004
INTEGRATION_SERVICE_HOST=integration-service
INTEGRATION_SERVICE_PORT=8005
